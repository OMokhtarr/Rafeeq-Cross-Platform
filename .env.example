# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# react-scripts injects every REACT_APP_* into the bundle at build time.

# URL of the Cloudflare Worker that brokers OAuth tokens for the
# Quran Foundation Content API. The Worker holds the client_id /
# client_secret as Worker secrets — they never touch this file.
# After `wrangler deploy` in the token-broker dir, paste the printed URL.
REACT_APP_TOKEN_BROKER_URL=https://rafeeq-token-broker.<your>.workers.dev

# OPTIONAL — override the content API base if you ever switch from prelive
# to production, or test against legacy v4. Defaults to the Foundation host.
# REACT_APP_CONTENT_API_BASE=https://apis.quran.foundation/content/api/v4

# OPTIONAL — sent as `x-client-id` on content calls. Some Foundation
# deployments require it alongside the bearer token; harmless if not.
# This is the public client_id only (NOT the secret).
# REACT_APP_QF_CLIENT_ID=
